{
    "name": "@metro-now/dataloader",
    "version": "1.0.0",
    "description": "Metro Now background sync worker",
    "main": "dist/app.js",
    "scripts": {
        "build": "rm -rf dist && tsc",
        "start": "node dist/app.js",
        "dev": "nodemon --watch src --ext ts --exec \"pnpm run build && pnpm run start\"",
        "lint": "biome check --config-path ../../biome.json ../../apps/dataloader/src ../../apps/dataloader/package.json ../../apps/dataloader/tsconfig.json",
        "lint:fix": "biome check --config-path ../../biome.json ../../apps/dataloader/src ../../apps/dataloader/package.json ../../apps/dataloader/tsconfig.json --write",
        "test:unit": "pnpm run build && node --test dist/**/*.spec.js",
        "types:check": "tsc --noEmit"
    },
    "keywords": [],
    "author": "",
    "license": "ISC",
    "dependencies": {
        "@fast-csv/parse": "^5.0.5",
        "@metro-now/database": "workspace:*",
        "@metro-now/shared": "workspace:*",
        "express": "^5.2.1",
        "ioredis": "^5.10.1",
        "node-cron": "^4.2.1",
        "radash": "^12.1.1",
        "unzipper": "^0.12.3",
        "zod": "^3.24.2"
    },
    "devDependencies": {
        "@types/express": "^5.0.6",
        "@types/node": "^25.5.0",
        "@types/node-cron": "^3.0.11",
        "@types/unzipper": "^0.10.11",
        "nodemon": "^3.1.14",
        "typescript": "^5.8.3"
    }
}
