{
    "name": "@metro-now/database",
    "main": "dist/index.js",
    "types": "dist/index.d.ts",
    "scripts": {
        "build": "tsc",
        "lint": "biome check --config-path ../../biome.json ../../apps/database/index.ts ../../apps/database/migrate.ts ../../apps/database/seed.ts ../../apps/database/migrations ../../apps/database/package.json ../../apps/database/tsconfig.json",
        "format": "biome format --config-path ../../biome.json ../../apps/database/index.ts ../../apps/database/migrate.ts ../../apps/database/seed.ts ../../apps/database/migrations ../../apps/database/package.json ../../apps/database/tsconfig.json --write",
        "format:check": "biome check --config-path ../../biome.json ../../apps/database/index.ts ../../apps/database/migrate.ts ../../apps/database/seed.ts ../../apps/database/migrations ../../apps/database/package.json ../../apps/database/tsconfig.json",
        "migrate:deploy": "dotenv -e ../backend/.env.local -- ts-node migrate.ts up",
        "migrate:rollback": "dotenv -e ../backend/.env.local -- ts-node migrate.ts down",
        "seed": "dotenv -e ../backend/.env.local -- ts-node seed.ts",
        "types:check": "tsc --noEmit"
    },
    "dependencies": {
        "kysely": "^0.28.14",
        "pg": "^8.20.0"
    },
    "devDependencies": {
        "@types/pg": "^8.15.5",
        "ts-node": "^10.9.2",
        "typescript": "^5.8.3"
    },
    "optionalDependencies": {
        "dotenv-cli": "^8.0.0"
    }
}
