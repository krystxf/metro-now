{
    "name": "@metro-now/backend",
    "scripts": {
        "typegen": "ts-node ./src/scripts/generate-types.ts",
        "validate:mobile-schema": "ts-node ./src/scripts/validate-mobile-schema.ts",
        "prebuild": "rimraf dist && pnpm typegen",
        "build": "nest build",
        "start": "nest start",
        "dev": "nest start --watch",
        "start:debug": "nest start --debug --watch",
        "start:prod": "node dist/main",
        "lint": "biome check --config-path ../../biome.json ../../apps/backend/src ../../apps/backend/package.json ../../apps/backend/tsconfig.json",
        "lint:fix": "biome check --config-path ../../biome.json ../../apps/backend/src ../../apps/backend/package.json ../../apps/backend/tsconfig.json --write",
        "types:check": "tsc --incremental --noEmit",
        "test:unit": "jest",
        "test:watch": "jest --watch",
        "test:cov": "jest --coverage",
        "test:debug": "node --inspect-brk -r tsconfig-paths/register -r ts-node/register node_modules/.bin/jest --runInBand",
        "test:e2e": "jest --config ./e2e/jest-e2e.json --runInBand"
    },
    "dependencies": {
        "@apollo/server": "^5.5.0",
        "@as-integrations/express5": "^1.1.2",
        "@fast-csv/parse": "^5.0.5",
        "@keyv/redis": "^5.1.6",
        "@metro-now/database": "workspace:*",
        "@metro-now/shared": "workspace:*",
        "@nestjs/apollo": "^13.2.4",
        "@nestjs/cache-manager": "^3.1.0",
        "@nestjs/common": "^11.1.17",
        "@nestjs/config": "^4.0.3",
        "@nestjs/core": "^11.1.17",
        "@nestjs/graphql": "^13.2.4",
        "@nestjs/platform-express": "^11.1.17",
        "cache-manager": "^7.2.8",
        "cacheable": "^2.3.4",
        "compression": "^1.8.1",
        "dataloader": "^2.2.3",
        "graphql": "^16.13.2",
        "keyv": "^5.6.0",
        "radash": "^12.1.1",
        "reflect-metadata": "^0.2.2",
        "rxjs": "^7.8.2",
        "ts-morph": "^25.0.1",
        "unzipper": "^0.12.3",
        "zod": "^3.24.2"
    },
    "devDependencies": {
        "@nestjs/cli": "^11.0.16",
        "@nestjs/schematics": "^11.0.9",
        "@nestjs/testing": "^11.1.17",
        "@types/compression": "^1.8.1",
        "@types/express": "^5.0.6",
        "@types/jest": "^29.5.14",
        "@types/node": "^22.14.0",
        "@types/supertest": "^6.0.3",
        "jest": "^29.7.0",
        "rimraf": "^6.1.3",
        "source-map-support": "^0.5.21",
        "supertest": "^7.2.2",
        "ts-jest": "^29.4.6",
        "ts-loader": "^9.5.4",
        "ts-node": "^10.9.2",
        "tsconfig-paths": "^4.2.0",
        "typescript": "^5.8.3"
    },
    "jest": {
        "moduleFileExtensions": ["js", "json", "ts"],
        "rootDir": "./",
        "modulePaths": ["<rootDir>"],
        "testRegex": ".*\\.spec\\.ts$",
        "transform": {
            "^.+\\.ts$": "ts-jest"
        },
        "collectCoverageFrom": ["**/*.(t|j)s"],
        "coverageDirectory": "../coverage",
        "testEnvironment": "node"
    }
}
