{
    "name": "@metro-now/shared",
    "version": "1.0.0",
    "main": "dist/index.js",
    "types": "dist/index.d.ts",
    "scripts": {
        "build": "rm -rf dist && tsc",
        "lint": "biome check --config-path ../../biome.json ../../lib/shared/src ../../lib/shared/package.json ../../lib/shared/tsconfig.json",
        "lint:fix": "biome check --config-path ../../biome.json ../../lib/shared/src ../../lib/shared/package.json ../../lib/shared/tsconfig.json --write",
        "test:unit": "pnpm run build && node --test $(find dist/tests -name '*.spec.js' -type f)",
        "types:check": "tsc --noEmit"
    },
    "dependencies": {
        "@metro-now/database": "workspace:*"
    },
    "devDependencies": {
        "@types/node": "^25.5.0",
        "typescript": "^5.8.3"
    }
}
