{
    "name": "metro-now",
    "description": "Monorepo includes backend, docs and apps for iOS and WatchOS",
    "packageManager": "pnpm@10.33.0",
    "engines": {
        "pnpm": ">=10.16.0"
    },
    "scripts": {
        "xcode": "xed ./apps/mobile/metro-now",
        "dev": "turbo run dev",
        "build": "turbo run build",
        "graphql:test": "node graphql-test/index.js",
        "lint": "turbo run lint",
        "lint:fix": "turbo run lint:fix",
        "app:format": "swiftformat apps/mobile",
        "test:unit": "turbo run test:unit",
        "types:check": "turbo run types:check",
        "typegen": "turbo run typegen",
        "docker:up:dev": "docker compose up postgres redis-stack",
        "docker:up": "docker compose up -d --build",
        "docker:down": "docker compose down --remove-orphans --volumes",
        "prepare": "husky"
    },
    "devDependencies": {
        "@biomejs/biome": "^1.9.4",
        "husky": "^9.1.7",
        "lint-staged": "^16.4.0",
        "turbo": "^2.5.0"
    },
    "homepage": "https://metro-now.vercel.app/",
    "repository": {
        "type": "git",
        "url": "https://github.com/krystxf/metro-now"
    },
    "bugs": {
        "url": "https://github.com/krystxf/metro-now/issues/new"
    },
    "author": {
        "name": "Krystof Kratky",
        "url": "https://github.com/krystxf",
        "email": "krystof.kratky2003@gmail.com"
    },
    "lint-staged": {
        "*.{js,ts,cjs,mjs,d.cts,d.mts,jsx,tsx,json,jsonc}": [
            "biome check --write --no-errors-on-unmatched --files-ignore-unknown=true"
        ]
    },
    "pnpm": {
        "overrides": {
            "sha.js": ">=2.4.12",
            "form-data": ">=4.0.4"
        },
        "onlyBuiltDependencies": ["@nestjs/core"]
    }
}
