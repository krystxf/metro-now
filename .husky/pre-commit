#!/usr/bin/env sh
set -e
cd "$(dirname "$0")/.." || exit 1

pnpm exec lint-staged

if command -v swiftformat >/dev/null 2>&1; then
	pnpm app:format
else
	STAGED_SWIFT=$(git diff --cached --name-only --diff-filter=ACM | grep -E '^apps/mobile/.*\.swift$' || true)
	if [ -n "$STAGED_SWIFT" ]; then
		echo "pre-commit: swiftformat is required when committing Swift under apps/mobile. Install: brew install swiftformat" >&2
		exit 1
	fi
fi

# Re-stage files modified by swiftformat so the commit includes fixes
if [ -n "$(git diff --name-only)" ]; then
	git diff --name-only -z | xargs -0 git add
fi
