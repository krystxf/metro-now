#!/usr/bin/env sh
set -e
cd "$(dirname "$0")/.." || exit 1

if git diff --cached --name-only --diff-filter=ACM \
	| grep -qE '^apps/mobile/.*\.swift$' \
	&& ! command -v swiftformat >/dev/null 2>&1
then
	echo "pre-commit: swiftformat is required when committing Swift under apps/mobile. Install: brew install swiftformat" >&2
	exit 1
fi

pnpm exec lint-staged
